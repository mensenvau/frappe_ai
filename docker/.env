# ---------------------------------------------------------------------------
# Mason platform — docker environment
# ---------------------------------------------------------------------------
# Copy/edit values as needed, then: `docker compose up -d`
# Everything here is consumed by docker/docker-compose.yml.

# Frappe / bench
FRAPPE_VERSION=version-15
PYTHON_VERSION=3.11

# Site
SITE_NAME=mason.localhost
DEVELOPER_MODE=1

# Admin
ADMIN_PASSWORD=admin

# MariaDB
DB_ROOT_PASSWORD=123
DB_HOST=mariadb
DB_PORT=3306

# Redis
REDIS_CACHE=redis-cache:6379
REDIS_QUEUE=redis-queue:6379

# Host port the Desk is served on (http://localhost:8080)
HTTP_PORT=8080
